
// Test Regression and Functions
import { LinearRegression } from "../src/math/statistics.dryad";
import { floor, ceil, round, random, seed } from "../src/scientific/functions.dryad";
#<console_io>

function assert(condition, message) {
    if (!condition) {
        println("FAIL: " + message);
    } else {
        println("PASS: " + message);
    }
}

function test_functions() {
    println("Testing Functions...");
    assert(floor(3.7) == 3, "floor(3.7)");
    assert(floor(-3.7) == -4, "floor(-3.7)");
    assert(ceil(3.2) == 4, "ceil(3.2)");
    assert(round(3.5) == 4, "round(3.5)");
    assert(round(3.4) == 3, "round(3.4)");
    
    seed(42);
    let r1 = random();
    let r2 = random();
    assert(r1 != r2, "Random variance");
    assert(r1 >= 0 && r1 < 1, "Random range");
}

function test_regression() {
    println("Testing Regression...");
    // Simple 1D linear data: y = 2x + 1
    let X = [[1], [2], [3], [4], [5]];
    let y = [3, 5, 7, 9, 11];
    
    let model = new LinearRegression();
    model.fit(X, y);
    
    println("Intercept: " + model.intercept);
    println("Coeff: " + model.coefficients[0]);
    
    // Check close to 1 and 2
    assert(model.intercept > 0.9 && model.intercept < 1.1, "Intercept approx 1");
    assert(model.coefficients[0] > 1.9 && model.coefficients[0] < 2.1, "Slope approx 2");
    
    let pred = model.predict([[6]]);
    println("Prediction for 6: " + pred[0]);
    assert(pred[0] > 12.9 && pred[0] < 13.1, "Predict(6) approx 13");
}

test_functions();
test_regression();
