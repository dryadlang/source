// ============================================================
// 7. Combined example: Mini API service
// ============================================================
println("\n=== 7. Combined example: API service sketch ===");

// This sketch shows how multiple modules work together.
// Actual execution requires network access.

println("Architecture:");
println("  1. #<http_server> creates REST endpoints");
println("  2. #<encode_decode> encodes/decodes JSON payloads");
println("  3. #<tcp> handles low-level connections if needed");
println("  4. #<json_stream> parses large streaming responses");
println("  5. #<websocket> enables real-time communication");
println("  6. #<ffi> calls native C libraries for performance");

// Demonstrating encode/decode which works without network:
let apiResponse = {
    status: "success",
    data: {
        users: [
            { id: 1, name: "Alice" },
            { id: 2, name: "Bob" }
        ],
        total: 2
    },
    timestamp: native_now()
};

let jsonPayload = native_json_encode(apiResponse);
println("\nSerialized API response:");
println(jsonPayload);

let deserialized = native_json_decode(jsonPayload);
println("\nDeserialized status: " + deserialized.status);
println("User count: " + deserialized.data.total);

println("\nAdvanced features demo complete!");
