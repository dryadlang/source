
// Test script for Fern Symbolic Algebra
import { symbol, number, add, subtract, multiply, divide, power, simplify } from "../src/symbolic/algebra.dryad";

println("Running Symbolic Algebra Tests...");

let x = symbol("x");
let two = number(2);
let three = number(3);

// f(x) = 2x + 3
let f = add(multiply(two, x), three);
println("Function: " + f.to_string());

// Eval at x=5
let ctx = {"x": 5};
let res = f.evaluate(ctx);
println("f(5): " + res);
if (res != 13) println("FAIL: f(5) should be 13");

// Derivative f'(x) = 2
let df = f.derivative("x");
println("f'(x): " + df.to_string());
let dres = df.evaluate(ctx);
println("f'(5): " + dres);
if (dres != 2) println("FAIL: f'(5) should be 2");

// Integration
let int_f = f.integrate("x");
println("Integral of 2x + 3: " + int_f.to_string());
// Should be 0.5 * 2 * x^2 + 3x 

// Simplify
let s_expr = add(number(5), number(10));
println("Simplify 5+10: " + simplify(s_expr).to_string());
if (simplify(s_expr).evaluate({}) != 15) println("FAIL: simplify wrong");

println("Algebra Tests Completed.");
