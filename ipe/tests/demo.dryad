#<console_io>
#<ffi>
#<system_env>

function main() {
    println("Starting Ipe Framework demo...");
    
    // Load the library based on platform
    let platform = native_platform();
    let ext = ".so";
    if (platform == "windows") { ext = ".dll"; }
    
    let path = "./ipe/native/ipe" + ext;
    println("Loading library: " + path);
    
    if (!ffi_load_library(path, "ipe")) {
        println("Failed to load library");
        return;
    }
    
    println("Initializing Ipe...");
    let init_result = ffi_call("ipe", "ipe_init", "i32");
    if (init_result == 0) {
        println("Failed to initialize Ipe");
        return;
    }
    println("Ipe initialized successfully!");
    
    println("Creating window...");
    let window = ffi_call("ipe", "ipe_window_create", "pointer", 800, 600, "Ipe Framework Demo");
    if (window == 0) {
        println("Failed to create window");
        return;
    }
    println("Window created successfully!");
    println("Press ESC or close the window to exit...");
    
    // Main loop - run until user closes window
    let running = 1;
    let frame = 0;
    while (running != 0) {
        // Process events (returns 0 if window closed)
        running = ffi_call("ipe", "ipe_process_events", "i32");
        
        // Clear with dark gray
        ffi_call("ipe", "ipe_clear_background", "void", 0xFF333333);
        
        // Draw animated red rectangle (moving horizontally)
        let x_pos = 100 + (frame % 400);
        ffi_call("ipe", "ipe_draw_rect", "void", x_pos, 100, 200, 150, 0xFFFF0000);
        
        // Draw blue rectangle (static)
        ffi_call("ipe", "ipe_draw_rect", "void", 400, 300, 100, 100, 0xFF0000FF);
        
        // Draw some text
        ffi_call("ipe", "ipe_draw_text", "void", "IPE Framework - Dryad Graphics", 250, 500, 0xFFFFFFFF);
        
        // PRESENT the frame to show it on screen!
        ffi_call("ipe", "ipe_present", "void");
        
        frame = frame + 1;
        
        // Small delay to not spin the CPU (approximately 60 FPS)
        // Note: In a real app you'd use proper timing
    }
    
    println("Window closed. Cleaning up...");
    ffi_call("ipe", "ipe_window_close", "void");
    println("Demo completed successfully!");
}

main();
