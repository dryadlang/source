#<console_io>
#<ffi>
#<system_env>

function print_banner(title) {
    println("╔════════════════════════════════════════════════════════╗");
    println("║  " + title);
    println("╚════════════════════════════════════════════════════════╝");
}

function print_section(text) {
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    println("TEST: " + text);
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

function test_platform_detection() {
    print_section("Platform Detection (SDL2 Cross-Platform)");
    
    let platform = native_platform();
    let ext = ".so";
    
    if (platform == "windows") {
        ext = ".dll";
    } else if (platform == "macos") {
        ext = ".dylib";
    }
    
    println("  Platform: " + platform);
    println("  Expected extension: " + ext);
    
    let path = "./ipe/native/ipe" + ext;
    println("  Library path: " + path);
    
    println("[✓] Platform detection OK");
    return path;
}

function test_library_loading(lib_path) {
    print_section("Library Loading (SDL2 Build)");
    
    println("  Loading: " + lib_path);
    
    if (!ffi_load_library(lib_path, "ipe")) {
        println("[✗] Failed to load library");
        return 0;
    }
    
    println("[✓] Library loaded successfully");
    return 1;
}

function test_symbol_ipe_init() {
    print_section("Testing ipe_init Symbol");
    
    let result = ffi_call("ipe", "ipe_init", "i32");
    
    if (result != 1) {
        println("[✗] ipe_init returned " + result + " (expected 1)");
        return 0;
    }
    
    println("  ipe_init returned: " + result);
    println("[✓] ipe_init symbol OK");
    return 1;
}

function test_symbol_window_create() {
    print_section("Testing ipe_window_create Symbol");
    
    let window = ffi_call("ipe", "ipe_window_create", "pointer", 400, 300, "Test Window");
    
    if (window == 0) {
        println("[✗] ipe_window_create returned NULL");
        return 0;
    }
    
    println("  Window pointer: non-null");
    println("[✓] ipe_window_create symbol OK");
    return window;
}

function test_symbol_clear_background() {
    print_section("Testing ipe_clear_background Symbol");
    
    ffi_call("ipe", "ipe_clear_background", "void", 0x333333);
    
    println("  Cleared background with color 0x333333");
    println("[✓] ipe_clear_background symbol OK");
    return 1;
}

function test_symbol_draw_rect() {
    print_section("Testing ipe_draw_rect Symbol");
    
    ffi_call("ipe", "ipe_draw_rect", "void", 50, 50, 100, 100, 0xFF0000);
    ffi_call("ipe", "ipe_draw_rect", "void", 200, 150, 80, 80, 0x00FF00);
    
    println("  Drew 2 rectangles");
    println("[✓] ipe_draw_rect symbol OK");
    return 1;
}

function test_symbol_process_events() {
    print_section("Testing ipe_process_events Symbol");
    
    let running = ffi_call("ipe", "ipe_process_events", "i32");
    
    println("  Process events returned: " + running);
    println("[✓] ipe_process_events symbol OK");
    return 1;
}

function test_symbol_is_window_open() {
    print_section("Testing ipe_is_window_open Symbol");
    
    let open = ffi_call("ipe", "ipe_is_window_open", "i32");
    
    println("  Window open status: " + open);
    println("[✓] ipe_is_window_open symbol OK");
    return 1;
}

function test_symbol_window_close() {
    print_section("Testing ipe_window_close Symbol");
    
    ffi_call("ipe", "ipe_window_close", "void");
    
    println("  Window closed");
    println("[✓] ipe_window_close symbol OK");
    return 1;
}

function main() {
    print_banner("SDL2 Cross-Platform Integration Test Suite");
    
    let lib_path = test_platform_detection();
    
    if (test_library_loading(lib_path) == 0) {
        println("\n[✗] FAILED: Could not load library");
        return;
    }
    
    if (test_symbol_ipe_init() == 0) {
        println("\n[✗] FAILED: ipe_init symbol");
        return;
    }
    
    let window = test_symbol_window_create();
    if (window == 0) {
        println("\n[✗] FAILED: ipe_window_create symbol");
        return;
    }
    
    test_symbol_clear_background();
    test_symbol_draw_rect();
    test_symbol_process_events();
    test_symbol_is_window_open();
    test_symbol_window_close();
    
    println("\n╔════════════════════════════════════════════════════════╗");
    println("║  All Tests Passed! SDL2 Cross-Platform Works!        ║");
    println("╚════════════════════════════════════════════════════════╝");
}

main();
