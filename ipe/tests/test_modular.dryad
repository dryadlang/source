#<console_io>
#<ffi>
#<system_env>

// IPE Modular Demo

let ipe_lib = "ipe";
let initialized = false;

function load_ipe() {
    let platform = native_platform();
    let ext = ".so";
    if (platform == "windows") {
        ext = ".dll";
    }
    let path = "./ipe/native/ipe" + ext;
    return ffi_load_library(path, ipe_lib);
}

function init_ipe() {
    if (!load_ipe()) {
        println("[X] Failed to load library");
        return false;
    }
    let result = ffi_call(ipe_lib, "ipe_init", "i32");
    if (result == 0) {
        println("[X] Failed to initialize");
        return false;
    }
    initialized = true;
    return true;
}

function main() {
    println("=== IPE Modular Demo ===");
    
    if (!init_ipe()) {
        return;
    }
    println("[OK] IPE initialized");
    
    let win = ffi_call(ipe_lib, "ipe_window_create", "pointer", 800, 600, "Demo");
    if (win == 0) {
        println("[X] Failed to create window");
        return;
    }
    println("[OK] Window created");
    println("Running... Press ESC to exit");
    
    let anim_x = 100;
    let hue = 0;
    
    while (ffi_call(ipe_lib, "ipe_is_window_open", "i32") != 0) {
        ffi_call(ipe_lib, "ipe_process_events", "void");
        
        // Check ESC
        if (ffi_call(ipe_lib, "ipe_event_has_key_down", "i32") != 0) {
            let key = ffi_call(ipe_lib, "ipe_input_get_key_code", "i32");
            if (key == 27) {
                break;
            }
        }
        
        // Animate
        anim_x = anim_x + 2;
        if (anim_x > 650) { anim_x = 100; }
        hue = (hue + 1) % 360;
        
        // Draw
        ffi_call(ipe_lib, "ipe_clear_background", "void", 0xFF1A1A2E);
        ffi_call(ipe_lib, "ipe_draw_text", "void", "IPE Modular Demo - Press ESC", 250, 50, 0xFFFFFFFF);
        
        // Rainbow rect
        let r = 0;
        let g = 0;
        let b = 0;
        if (hue < 60) { r = 255; g = (hue * 255) / 60; }
        else if (hue < 120) { r = ((120 - hue) * 255) / 60; g = 255; }
        else if (hue < 180) { g = 255; b = ((hue - 120) * 255) / 60; }
        else if (hue < 240) { g = ((240 - hue) * 255) / 60; b = 255; }
        else if (hue < 300) { r = ((hue - 240) * 255) / 60; b = 255; }
        else { r = 255; b = ((360 - hue) * 255) / 60; }
        let color = 0xFF000000 | (b << 16) | (g << 8) | r;
        
        ffi_call(ipe_lib, "ipe_draw_rect", "void", anim_x, 200, 100, 60, color);
        
        // Mouse pos
        let mx = ffi_call(ipe_lib, "ipe_input_mouse_x", "i32");
        let my = ffi_call(ipe_lib, "ipe_input_mouse_y", "i32");
        ffi_call(ipe_lib, "ipe_draw_text", "void", "Mouse: " + mx + ", " + my, 50, 500, 0xFFFFFFFF);
        
        ffi_call(ipe_lib, "ipe_present", "void");
        ffi_call(ipe_lib, "ipe_input_clear_events", "void");
    }
    
    ffi_call(ipe_lib, "ipe_window_close", "void");
    println("Done!");
}

main();
