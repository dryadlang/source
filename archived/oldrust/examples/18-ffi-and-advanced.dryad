println("\n=== 5. #<json_stream> — Incremental JSON Processing ===");

// Parse a JSON string incrementally
let jsonStr = "{\"name\":\"Dryad\",\"version\":1}";
let parsed = json_parse_incremental(jsonStr);
println("Incremental parse: " + parsed);

