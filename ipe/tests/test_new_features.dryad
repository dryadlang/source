#<console_io>
#<ffi>
#<system_env>

// Wrapper functions para a API do IPE
let ipe_lib_loaded = false;
let ipe_lib_alias = "ipe";

function ipe_load_library() {
    if (ipe_lib_loaded) {
        return true;
    }
    
    let platform = native_platform();
    let ext = ".so";
    if (platform == "windows") {
        ext = ".dll";
    }
    
    let path = "./ipe/native/ipe" + ext;
    if (ffi_load_library(path, ipe_lib_alias)) {
        ipe_lib_loaded = true;
        return true;
    }
    return false;
}

function ipe_init() {
    if (!ipe_load_library()) {
        return false;
    }
    return ffi_call(ipe_lib_alias, "ipe_init", "i32") != 0;
}

function ipe_create_window(w, h, title) {
    if (!ipe_lib_loaded) {
        return 0;
    }
    return ffi_call(ipe_lib_alias, "ipe_window_create", "pointer", w, h, title);
}

function ipe_clear(color) {
    if (!ipe_lib_loaded) {
        return;
    }
    ffi_call(ipe_lib_alias, "ipe_clear_background", "void", color);
}

function ipe_draw_rect(x, y, w, h, color) {
    if (!ipe_lib_loaded) {
        return;
    }
    ffi_call(ipe_lib_alias, "ipe_draw_rect", "void", x, y, w, h, color);
}

function ipe_draw_text(text, x, y, color) {
    if (!ipe_lib_loaded) {
        return;
    }
    ffi_call(ipe_lib_alias, "ipe_draw_text", "void", text, x, y, color);
}

function ipe_present() {
    if (!ipe_lib_loaded) {
        return;
    }
    ffi_call(ipe_lib_alias, "ipe_present", "void");
}

function ipe_transform_push() {
    if (!ipe_lib_loaded) {
        return;
    }
    ffi_call(ipe_lib_alias, "ipe_transform_push", "void");
}

function ipe_transform_pop() {
    if (!ipe_lib_loaded) {
        return;
    }
    ffi_call(ipe_lib_alias, "ipe_transform_pop", "void");
}

function ipe_translate(dx, dy) {
    if (!ipe_lib_loaded) {
        return;
    }
    ffi_call(ipe_lib_alias, "ipe_transform_translate", "void", dx, dy);
}

function ipe_scale(sx, sy) {
    if (!ipe_lib_loaded) {
        return;
    }
    ffi_call(ipe_lib_alias, "ipe_transform_scale", "void", sx, sy);
}

function ipe_rotate(angle) {
    if (!ipe_lib_loaded) {
        return;
    }
    ffi_call(ipe_lib_alias, "ipe_transform_rotate", "void", angle);
}

function ipe_is_open() {
    if (!ipe_lib_loaded) {
        return false;
    }
    return ffi_call(ipe_lib_alias, "ipe_is_window_open", "i32") != 0;
}

function ipe_process_events() {
    if (!ipe_lib_loaded) {
        return;
    }
    ffi_call(ipe_lib_alias, "ipe_process_events", "void");
}

function ipe_close() {
    if (!ipe_lib_loaded) {
        return;
    }
    ffi_call(ipe_lib_alias, "ipe_window_close", "void");
    ipe_lib_loaded = false;
}

function ipe_font_load(path, size) {
    if (!ipe_lib_loaded) {
        return 0;
    }
    return ffi_call(ipe_lib_alias, "ipe_font_load", "pointer", path, size);
}

function main() {
    println("Starting IPE Feature Verification...");
    
    // Initialize
    if (!ipe_init()) {
        println("Failed to initialize IPE framework");
        return;
    }
    
    println("Creating window...");
    let win = ipe_create_window(800, 600, "IPE Feature Verification");
    if (win == 0) {
        println("Failed to create window");
        return;
    }
    
    // Pre-load font
    println("Loading font...");
    let font = ipe_font_load("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf", 24);
    if (font == 0) {
        println("Warning: Could not load font. Text might not work.");
    }
    
    println("Entering main loop...");
    while (ipe_is_open()) {
        ipe_process_events();
        ipe_clear(0xFF222222);
        
        // 1. Test basic draw
        ipe_draw_rect(50, 50, 100, 50, 0xFFFFFFFF);
        ipe_draw_text("Standard White Rect", 50, 110, 0xFFFFFFFF);
        
        // 2. Test Transformations
        ipe_transform_push();
        ipe_translate(400, 100);
        ipe_rotate(30);
        ipe_draw_rect(0, 0, 100, 50, 0xFF0000FF);
        ipe_draw_text("Transformed Red Rect", 0, 60, 0xFF0000FF);
        ipe_transform_pop();
        
        // 3. Test Scaling
        ipe_transform_push();
        ipe_translate(100, 300);
        ipe_scale(1.5, 1.5);
        ipe_draw_rect(0, 0, 100, 50, 0xFF00FF);
        ipe_draw_text("Scaled Green Rect", 0, 60, 0xFF00FF);
        ipe_transform_pop();
        
        // 4. Present
        ipe_present();
    }
    
    println("Cleaning up...");
    ipe_close();
    println("Verification completed.");
}

main();
